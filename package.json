{
  "name": "cf-temp-email",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy && wrangler d1 migrations apply DB --remote",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "deploy:worker": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test:smoke": "node scripts/request-smoke.mjs"
  },
  "dependencies": {
    "hono": "^4.8.3",
    "postal-mime": "^2.4.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260508.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.15.0"
  }
}
